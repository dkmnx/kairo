    "env_vars": [
      "ANTHROPIC_SMALL_FAST_MODEL_TIMEOUT=120",
      "ANTHROPIC_SMALL_FAST_MAX_TOKENS=24576"
    ],
    "api_key_env_var": "MINIMAX_API_KEY",
    "key_format": {"min_length": 32, "prefix": "", "pattern": ""}
  },
