{
  "zai": {
    "name": "Z.AI",
    "base_url": "https://api.z.ai/api/anthropic",
    "model": "glm-5.1",
    "requires_api_key": true,
    "env_vars": ["ANTHROPIC_DEFAULT_HAIKU_MODEL=glm-4.7-flash"],
    "api_key_env_var": "ZAI_API_KEY",
    "key_format": {"min_length": 32, "prefix": "", "pattern": ""}
  },
